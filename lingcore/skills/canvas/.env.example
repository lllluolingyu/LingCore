# Generic Canvas configuration template. Keep this safe example beside the
# skill so its requirements are easy to find, but store real values with the
# profile that engages it. The bundled teaching profile has a combined example
# (including its LLM key) — copy that one instead:
#
#   cp profiles/teaching/.env.example profiles/teaching/.env
#
# The destination .env is gitignored. Its values take precedence over exported
# process variables with the same names.
# This template covers Canvas only; the engaging profile may separately require
# an LLM-provider API key.

# Your school's Canvas instance, e.g. https://your-school.instructure.com
CANVAS_URL=
CANVAS_TOKEN=
