# Copy to profiles/teaching/.env and fill the secret values. The copied .env is
# gitignored and overrides same-named variables exported by the shell.

LLY_API_KEY=
# Your school's Canvas instance, e.g. https://your-school.instructure.com
CANVAS_URL=
CANVAS_TOKEN=

# Optional LLM/profile overrides:
# LINGCORE_MODEL=claude-opus-4-8
# LINGCORE_BASE_URL=https://your-provider.example/v1
# LINGCORE_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_API_KEY=
# LINGCORE_WORKSPACE=/absolute/path/to/course-workspace
